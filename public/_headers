# Cloudflare Pages header rules — applied at the edge before the asset is served.
# Cache-Control rules: hashed assets get a year, root HTML stays revalidated.
# Security headers: strict CSP, HSTS, no framing, no MIME sniff.

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), gyroscope=(), microphone=(), payment=(), usb=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

# Vite hashes JS and CSS — safe to cache forever.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Static assets we own and rev manually.
/favicon.svg
  Cache-Control: public, max-age=86400
/og.jpg
  Cache-Control: public, max-age=604800
/og.svg
  Cache-Control: public, max-age=604800

# Root HTML — keep edge cached briefly so deploys propagate quickly.
/
  Cache-Control: public, max-age=300, must-revalidate
/index.html
  Cache-Control: public, max-age=300, must-revalidate

# AEO files — let crawlers cache for a day.
/robots.txt
  Cache-Control: public, max-age=86400
/sitemap.xml
  Cache-Control: public, max-age=86400
/llms.txt
  Cache-Control: public, max-age=86400
