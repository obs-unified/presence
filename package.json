{
  "name": "presence",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Landing page for obs-unified — self-hosted observability for traces, logs, AI calls, and session replay.",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && tsx scripts/prerender.ts",
    "preview": "vite preview",
    "types:check": "tsc --noEmit",
    "deploy": "pnpm build && wrangler pages deploy ./dist --project-name=obsunified --branch=main --commit-dirty=true",
    "deploy:preview": "pnpm build && wrangler pages deploy ./dist --project-name=obsunified --branch=preview --commit-dirty=true"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
